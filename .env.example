# Slack — https://api.slack.com/apps → App Credentials & Basic Information
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=
# Random string, min 16 characters (OAuth state)
SLACK_STATE_SECRET=change_me_at_least_16_chars

# Public base URL (no trailing slash)
# Slack redirect: {APP_BASE_URL}/slack/oauth_redirect
# Google redirect: {APP_BASE_URL}/oauth/google/callback
APP_BASE_URL=http://localhost:3000

# Local Postgres (see docker-compose.yml)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/slacker_mail

# Google Cloud — OAuth 2.0 Web client + Gmail API + Pub/Sub topic resource name
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_PUBSUB_TOPIC=projects/YOUR_PROJECT_ID/topics/YOUR_TOPIC

# Optional — if set, POST /webhooks/gmail-pubsub must send matching auth (see src/routes/pubsub.ts)
# PUBSUB_PUSH_SECRET=

# Encrypts tokens at rest — must be 32 bytes when base64-decoded: openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=

PORT=3000
NODE_ENV=development
