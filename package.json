{
  "name": "slacker-mail",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "echo '[build] start' && node --max-old-space-size=1536 node_modules/typescript/lib/tsc.js && node --input-type=module -e \"import { cpSync } from 'node:fs'; cpSync('src/db/migrations', 'dist/db/migrations', { recursive: true });\" && echo '[build] done'",
    "build:verbose": "node --max-old-space-size=1536 node_modules/typescript/lib/tsc.js --version && node --max-old-space-size=1536 node_modules/typescript/lib/tsc.js --diagnostics --listEmittedFiles",
    "build:list-inputs": "node --max-old-space-size=1536 node_modules/typescript/lib/tsc.js --listFilesOnly",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "migrate": "tsx src/db/migrate.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@slack/bolt": "^4.6.0",
    "express": "^4.21.2",
    "dotenv": "^16.4.7",
    "googleapis": "^148.0.0",
    "pg": "^8.14.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/pg": "^8.11.11",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
